// Import Knot helpers
#import "lib/knot.typ": *

// ============================================
// Codly Configuration (syntax highlighting)
// ============================================
#import "@preview/codly:1.3.0": *
#show: codly-init

// Language-specific colors
#codly(
  languages: (
    r: (name: "R", icon: "", color: rgb("#CE412B")),
    python: (name: "Python", icon: "", color: rgb("#3572A5")),
    output: (name: "#>", icon: "", color: rgb("#9999"))
  ),
)

#lorem(200)


```{r}
#| show: 'code'
x <- 1:5
```

#lorem(10)

```{r}
#| show: 'both'

y <- 1:2
x + y
```

#lorem(200)

```{r}
x <- 1:3
y <- 1:2
```
