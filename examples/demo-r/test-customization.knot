#import "lib/knot.typ": *

= Test Chunk Customization

== Default Layout (Horizontal)

```{r}
x <- 1:5
print(x)
```

== Vertical Layout

```{r}
#| layout: "vertical"
data <- data.frame(
  name = c("Alice", "Bob", "Charlie"),
  age = c(25, 30, 35)
)
print(data)
```

== Output Only

```{r}
#| layout: "output-only"
summary(1:100)
```

== Input Only (code still executes, just hides output)

```{r}
#| layout: "input-only"
# This code executes but output is hidden
x <- 1:10
mean(x)
```

== Custom Styling

```{r}
#| code-background: "#fef3cd"
#| output-background: "#d1ecf1"
#| code-stroke: "1pt + gray"
#| output-stroke: "1pt + blue"
result <- sum(1:10)
cat("Sum:", result, "\n")
```

== Custom Width Ratio

```{r}
#| width-ratio: "2:1"
# Code takes 2/3, output takes 1/3
x <- rnorm(5)
round(x, 2)
```

== Large Gutter

```{r}
#| gutter: "3em"
a <- 5
b <- 10
a + b
```
