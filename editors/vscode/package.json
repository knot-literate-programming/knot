{
  "name": "knot",
  "displayName": "Knot",
  "description": "Language support for Knot files (.knot) - Literate programming with R and Typst",
  "version": "0.3.1",
  "publisher": "knot-dev",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "knot",
    "typst",
    "R",
    "literate programming",
    "reproducible research"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nklutchnikoff/knot"
  },
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "knotExplorer",
          "name": "Knot Project"
        }
      ]
    },
    "languages": [
      {
        "id": "knot",
        "aliases": [
          "Knot",
          "knot"
        ],
        "extensions": [
          ".knot"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/knot-light.svg",
          "dark": "./icons/knot-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "knot",
        "scopeName": "source.knot",
        "path": "./syntaxes/knot.tmLanguage.json",
        "embeddedLanguages": {
          "source.r": "r",
          "meta.embedded.block.r": "r",
          "meta.embedded.inline.r": "r",
          "source.python": "python",
          "meta.embedded.block.python": "python",
          "meta.embedded.inline.python": "python"
        }
      }
    ],
    "commands": [
      {
        "command": "knot.openPreview",
        "title": "Open Preview",
        "category": "Knot",
        "icon": "$(open-preview)"
      },
      {
        "command": "knot.cleanProject",
        "title": "Clean Project (Clear Cache)",
        "category": "Knot",
        "icon": "$(trash)"
      },
      {
        "command": "knot.runDocument",
        "title": "Run Document",
        "category": "Knot",
        "icon": "$(play)"
      },
      {
        "command": "knot.buildProject",
        "title": "Build PDF",
        "category": "Knot",
        "icon": "$(file-pdf)"
      },
      {
        "command": "knot.formatChunk",
        "title": "Format Chunk",
        "category": "Knot",
        "icon": "$(zap)"
      },
      {
        "command": "knot.jumpToKnot",
        "title": "Jump to source (.knot)",
        "category": "Knot",
        "icon": "$(go-to-file)"
      },
      {
        "command": "knot.jumpToTyp",
        "title": "Jump to compiled (.typ)",
        "category": "Knot",
        "icon": "$(go-to-file)"
      },
      {
        "command": "knot.insertChunkR",
        "title": "Insert R Chunk",
        "category": "Knot",
        "icon": "$(add)"
      },
      {
        "command": "knot.insertChunkPython",
        "title": "Insert Python Chunk",
        "category": "Knot",
        "icon": "$(add)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "knot.formatChunk",
          "when": "resourceLangId == knot",
          "group": "1_modification"
        },
        {
          "command": "knot.jumpToTyp",
          "when": "resourceLangId == knot",
          "group": "navigation"
        },
        {
          "command": "knot.jumpToKnot",
          "when": "resourceLangId == typst",
          "group": "navigation"
        },
        {
          "command": "knot.insertChunkR",
          "when": "resourceLangId == knot",
          "group": "1_modification"
        },
        {
          "command": "knot.insertChunkPython",
          "when": "resourceLangId == knot",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "knot.cleanProject",
          "when": "resourceLangId == knot",
          "group": "navigation@3"
        },
        {
          "command": "knot.openPreview",
          "when": "resourceLangId == knot",
          "group": "navigation@0"
        },
        {
          "command": "knot.runDocument",
          "when": "resourceLangId == knot",
          "enablement": "knot.documentHasChanges",
          "group": "navigation@1"
        },
        {
          "command": "knot.buildProject",
          "when": "resourceLangId == knot",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "knot.openPreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "resourceLangId == knot"
      },
      {
        "command": "knot.jumpToTyp",
        "key": "ctrl+k t",
        "mac": "cmd+k t",
        "when": "resourceLangId == knot"
      },
      {
        "command": "knot.jumpToKnot",
        "key": "ctrl+k j",
        "mac": "cmd+k j",
        "when": "resourceLangId == typst"
      },
      {
        "command": "knot.formatChunk",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "resourceLangId == knot && editorTextFocus"
      },
      {
        "command": "knot.insertChunkR",
        "key": "ctrl+k r",
        "mac": "cmd+k r",
        "when": "resourceLangId == knot && editorTextFocus"
      },
      {
        "command": "knot.insertChunkPython",
        "key": "ctrl+k p",
        "mac": "cmd+k p",
        "when": "resourceLangId == knot && editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Knot",
      "properties": {
        "knot.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Knot Language Server"
        },
        "knot.lsp.path": {
          "type": "string",
          "default": "knot-lsp",
          "description": "Path to knot-lsp executable"
        },
        "knot.preview.pdfViewer": {
          "type": "string",
          "enum": [
            "vscode",
            "external"
          ],
          "default": "vscode",
          "description": "PDF viewer to use for preview (vscode: built-in PDF viewer, external: system default)"
        },
        "knot.formatter.air.path": {
          "type": "string",
          "default": "air",
          "description": "Path to Air formatter executable (used for R chunks)"
        },
        "knot.formatter.ruff.path": {
          "type": "string",
          "default": "ruff",
          "description": "Path to Ruff formatter executable (used for Python chunks)"
        },
        "knot.formatter.formatOnType": {
          "type": "boolean",
          "default": false,
          "description": "Format R chunks automatically on new line"
        },
        "knot.formatter.formatOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Format R chunks automatically on save"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run clean && npm run bundle -- --production",
    "compile": "npm run bundle",
    "bundle": "node esbuild.js",
    "clean": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\"",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --allow-missing-repository",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.x",
    "@typescript-eslint/parser": "^6.x",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.x",
    "typescript": "^5.3.0"
  }
}
